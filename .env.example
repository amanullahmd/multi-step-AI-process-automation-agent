# ============================================
# Multi-Step AI Process Automation Agent
# Copy this file to .env and fill in your values
# ============================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Model Configuration ---
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3

# --- Slack Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_ENABLED=false

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=reports@yourdomain.com
EMAIL_TO=you@example.com
EMAIL_ENABLED=false

# --- Scheduling ---
SCHEDULE_INTERVAL_HOURS=168
SCHEDULE_CRON=0 9 * * 1

# --- Database ---
DATABASE_PATH=data/price_history.db

# --- Scraping ---
SCRAPE_DELAY_SECONDS=2
SCRAPE_TIMEOUT_SECONDS=30
USER_AGENT=PriceMonitorAgent/1.0

# --- Analysis ---
# Minimum price change % to report — changes below this are treated as noise (default: 2%)
MIN_CHANGE_PCT=2.0

# --- LangSmith Observability (optional but recommended) ---
# Sign up free at https://smith.langchain.com, then enable tracing here.
# When enabled, every node invocation is logged to the LangSmith dashboard
# so you can inspect the agent's thought process, token usage and latency.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your-langsmith-api-key
LANGCHAIN_PROJECT=price-monitor-agent

# --- Logging ---
LOG_LEVEL=INFO
